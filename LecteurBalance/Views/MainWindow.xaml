<Window x:Class="LecteurBalance.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LecteurBalance"
        mc:Ignorable="d"
        Title="Weight Scale Reader" Height="450" Width="800">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Current Weight:" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
            <TextBlock Text="{Binding CurrentWeight}" FontSize="32" FontWeight="Bold" Foreground="Blue" Margin="0,0,0,15" />
            
            <StackPanel Orientation="Horizontal">
                <Button Content="Connect" Command="{Binding ConnectCommand}" Padding="15,10" FontSize="14" Margin="0,0,10,0" />
                <Button Content="Disconnect" Command="{Binding DisconnectCommand}" Padding="15,10" FontSize="14" Margin="0,0,10,0" />
                <Button Content="Settings" Command="{Binding OpenSettingsCommand}" Padding="15,10" FontSize="14" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>

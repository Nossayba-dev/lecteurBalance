<Window x:Class="LecteurBalance.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings" Height="300" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" />
            
            <TextBlock Text="COM Port:" FontWeight="Bold" Margin="0,0,0,5" />
            <TextBox Text="{Binding ComPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="8" Margin="0,0,0,15" />
            
            <TextBlock Text="Baud Rate:" FontWeight="Bold" Margin="0,0,0,5" />
            <TextBox Text="{Binding BaudRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="8" Margin="0,0,0,15" />
            
            <TextBlock Text="Server URL:" FontWeight="Bold" Margin="0,0,0,5" />
            <TextBox Text="{Binding ServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="8" Margin="0,0,0,20" />
            
            <TextBlock Text="{Binding StatusMessage}" Foreground="Green" Margin="0,0,0,15" FontSize="12" />
            
            <StackPanel Orientation="Horizontal">
                <Button Content="Save" Command="{Binding SaveCommand}" 
                        Padding="15,10" FontSize="14" Margin="0,0,10,0" />
                <Button Content="Reset" Command="{Binding ResetCommand}" 
                        Padding="15,10" FontSize="14" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
